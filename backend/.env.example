# ── Copy this to .env for local development ──────────────────────────────────

# Database
# Local dev: leave as SQLite. Render sets DATABASE_URL automatically when you
# attach the free PostgreSQL add-on.
DATABASE_URL=sqlite:///./finance.db

# Auth — generate a secret with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRE_MINUTES=1440
ADMIN_PASSWORD=your-secure-password

# Frontend URL (used for CORS — set to your Vercel URL in production)
FRONTEND_URL=http://localhost:5173

# Groq NLP — free key at https://console.groq.com
# Leave blank to disable NLP (regex fallback is used instead)
GROQ_API_KEY=

# ── Telegram ─────────────────────────────────────────────────────────────────
# Configured via the Settings page in the app — stored in app_settings.json.
# You do NOT need to set these here; they are saved through the UI.
# To get a bot token: message @BotFather on Telegram → /newbot
# To get your chat_id: message your bot → /start → fetch getUpdates
